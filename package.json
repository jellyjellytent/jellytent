{
  "name": "@jellyjelly/jellytent",
  "version": "0.3.0",
  "description": "AI video chat agent for JellyJelly",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./avatar": {
      "import": "./dist/avatar/index.mjs",
      "require": "./dist/avatar/index.js"
    }
  },
  "files": [
    "dist",
    "wasm"
  ],
  "scripts": {
    "build": "npm run build:wasm && npm run build:ts",
    "build:ts": "tsup",
    "build:wasm": "cd native/audio-processor && wasm-pack build --target web --out-dir ../../wasm",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist wasm"
  },
  "keywords": [
    "ai",
    "video-chat",
    "agent",
    "jellyjelly",
    "websocket",
    "voice",
    "avatar",
    "wasm"
  ],
  "author": "JellyJelly Inc.",
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.2",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "uuid": "^9.0.1",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  }
}
